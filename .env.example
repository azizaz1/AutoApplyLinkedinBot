# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/autoapply"

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — for sign in with Google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
GROQ_API_KEY=""

# ── Redis (for BullMQ job queues) ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── File uploads ──────────────────────────────────────────────────────────────
# For local dev: files saved to /public/uploads
# For production: use S3 / Cloudflare R2
UPLOAD_DIR="./public/uploads"

# Optional — S3 for production
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_BUCKET_NAME=""
# AWS_REGION="eu-west-1"

# ── Encryption key for stored platform passwords ───────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-32-byte-hex-key-here"
